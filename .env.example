# Predict.fun API key (request from their Discord for mainnet; testnet is open)
PREDICTFUN_API_KEY=your_key_here

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# Your personal chat ID (open https://api.telegram.org/bot<TOKEN>/getUpdates after /start)
TELEGRAM_CHAT_ID=123456789

# Wallet addresses to track, comma-separated (public addresses only, no private keys)
WALLET_ADDRESSES=0xYourPolymarketWallet,0xYourPredictFunWallet

# Internal auth secret between backend and bot containers (change this!)
INTERNAL_ALERT_SECRET=change_me_before_deploy

# Arbitrage thresholds (optional — these are the defaults)
MIN_MATCH_SCORE=82.0
MIN_ARB_PCT=0.5
MIN_PROFIT_USD=2.0
NOTIONAL_USD=100.0

# Polling intervals in seconds (optional — these are the defaults)
POLL_INTERVAL_POLY_SECONDS=3
MARKET_SYNC_INTERVAL_SECONDS=900
PORTFOLIO_SYNC_INTERVAL_SECONDS=120
